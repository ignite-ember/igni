<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hardened-Runtime entitlements for the notarized macOS bundle.

  - allow-jit / allow-unsigned-executable-memory: the WebKit webview
    JITs JavaScript at runtime. Without these the page crashes on
    first JS execution under hardened runtime.
  - disable-library-validation: the Tauri shell spawns
    ``python -m ember_code.backend`` and that interpreter loads .so
    extensions from pip-installed wheels (NOT signed by our team).
    Hardened runtime rejects unsigned dylibs by default; disabling
    library validation lets the bundled venv work as-is. Library
    integrity is still enforced for executables WE ship.
  - allow-dyld-environment-variables: ignite-ember sometimes sets
    ``DYLD_LIBRARY_PATH`` / ``DYLD_FALLBACK_LIBRARY_PATH`` for the
    spawned venv to find its libpython / native deps; hardened
    runtime strips these unless this entitlement is present.

  Network access is implicit for GUI apps; no entitlement needed.
  Outgoing-network sandbox is NOT applied here — igni is a
  developer tool with full filesystem + outbound HTTP requirements.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
