{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ember Code",
  "version": "0.6.0",
  "identifier": "sh.ignite-ember.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "beforeDevCommand": "npm --prefix ../web run dev",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ignite-ember/ember-code/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "PLACEHOLDER_UPDATER_PUBKEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI coding assistant with multi-agent orchestration",
    "longDescription": "Ember Code is an AI coding assistant with multi-agent orchestration. The desktop shell hosts the shared web UI and manages the local backend process — chat panel + project-locked sessions in a native window.",
    "copyright": "Copyright © 2026 Ignite Ember"
  }
}
