{
  "name": "ember-code-vscode",
  "displayName": "igni",
  "description": "AI coding assistant with multi-agent orchestration — chat panel with zero-touch backend install",
  "version": "0.7.1",
  "publisher": "ignite-ember",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "homepage": "https://ignite-ember.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/ignite-ember/igni"
  },
  "bugs": {
    "url": "https://github.com/ignite-ember/igni/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "chat",
    "coding-assistant",
    "claude",
    "openai"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "emberCode.open",
        "title": "Open Chat",
        "category": "igni"
      },
      {
        "command": "emberCode.addSelectionToChat",
        "title": "Add Selection to Ember Chat",
        "category": "igni"
      },
      {
        "command": "emberCode.addFileToChat",
        "title": "Add to Ember Chat",
        "category": "igni"
      },
      {
        "command": "emberCode.restart",
        "title": "Restart Backend",
        "category": "igni"
      },
      {
        "command": "emberCode.reinstall",
        "title": "Reinstall Backend (Clean)",
        "category": "igni"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "emberCode.addSelectionToChat",
          "group": "1_modification@1",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "emberCode.addFileToChat",
          "group": "1_modification@1",
          "when": "!explorerResourceIsFolder"
        }
      ]
    },
    "keybindings": [
      {
        "command": "emberCode.addSelectionToChat",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "igni",
      "properties": {
        "emberCode.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional: path to a Python interpreter with an editable ignite-ember install. Bypasses the managed venv. Intended for ember-code contributors; end users should leave empty so the extension manages everything via uv."
        }
      }
    }
  },
  "scripts": {
    "build:ui": "npm --prefix ../web run build && rm -rf media && cp -r ../web/dist media",
    "sync:version": "node ../../scripts/sync-version.mjs",
    "compile": "npm run sync:version && tsc -p .",
    "compile:test": "tsc -p tsconfig.test.json",
    "build": "npm run build:ui && npm run compile",
    "package": "npm run build && vsce package --no-dependencies",
    "watch": "tsc -w -p .",
    "test": "npm run compile && npm run compile:test && node out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.7.2"
  }
}
